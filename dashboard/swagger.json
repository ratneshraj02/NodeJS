{
  "openapi": "3.0.0",
  "info": {
    "title": "My API",
    "version": "1.0.0",
    "description": "This is the api for users"
  },
  "tags": [{ "name": "PUBLIC ROUTE", "description": "Public route" }],
  "paths": {
		"/health": {
			"summary": "Testing Health Check",
			"get": {
				"description": "Testing Users for pass",
				"tags": ["PUBLIC ROUTE"],
				"responses": {
					"200": {
						"description": "Health Check Pass"
					}
				}
			}
		},
		"/users": {
			"summary": "Testing User Check",
			"get": {
				"description": "Testing Users for pass",
				"tags": ["PUBLIC ROUTE"],
				"parameters": [
					{
						"in": "query",
						"name": "role",
						"schema": {
							"title": "string"
						},
						"description": "Choose role as admin or user"
					},
					{
						"in": "query",
						"name": "city",
						"schema": {
							"title": "string"
						},
						"description": "Enter city"
					}
				],
				"responses": {
					"200": {
						"description": "Users Pass"
					}
				}
			}
		},
		"/user/{id}": {
			"summary": "Testing User for app",
			"get": {
				"description": "Testing User for app",
				"tags": ["PUBLIC ROUTE"],
				"parameters": [
					{
						"in": "path",
						"name": "id",
						"required": true,
						"schema": {
							"title": "string"
						},
						"description": "Enter Object Id"
					}
				],
				"responses": {
					"200": {
						"description": "User Details"
					}
				}
			}
		},
		"/addUser": {
			"summary": "Testing User for app",
			"post": {
				"description": "Testing User for app",
				"tags": ["PUBLIC ROUTE"],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"id": "string",
								"type": "object"
							},
							"example": {
								"name": "Keerti",
								"city": "Sonpur",
								"phone": "8521223881",
								"role": "User",
								"isActive": true
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "User Details"
					}
				}
			}
		},
		"/updateUser": {
			"summary": "Update User",
			"put": {
				"description": "Testing Update User Details for the app",
				"tags": ["PUBLIC ROUTE"],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"id": "string",
								"type": "object"
							},
							"example": {
								"name": "Keerti",
								"city": "Sonpur",
								"phone": "8521223881",
								"role": "User",
								"isActive": true
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "User Details"
					}
				}
			}
		}
	}
}
